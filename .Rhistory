y_pos <- rep_len(y_pos, length.out = n)
plot[[2L]] <- plot[[2L]] + ggplot2::annotate(
geom = "text",
size = size,
x = I(x_pos), y = I(y_pos),
label = label,
hjust = 0, vjust = 0.5,
parse = TRUE
)
} else {
label[1L] <- header %||% "'Heterogeneity:'"
